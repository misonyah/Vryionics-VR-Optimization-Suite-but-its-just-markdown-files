# Build output
node_modules/
dist/
out/
*.tsbuildinfo

# Secrets — never commit
update-server/.gh-token
update-server/webhook.txt
**/.gh-token

# Publisher scripts — local-only, never pushed to public repo. The
# maintainer is the only person who should be able to publish releases;
# making the publisher source visible suggests "this is how to push to
# the main repo" even though anyone using it would need their own PAT.
# (The build still needs ps-helpers/ and storage-categories.json from
# this folder — those stay tracked because they ship to clients via
# electron-builder extraResources.)
update-server/publish.js
update-server/server.js
update-server/package.json
update-server/package-lock.json

# Maintainer-only launcher — depends on the gitignored server.js
# and contains a hardcoded local-machine path that's useless to anyone
# else and reveals the maintainer's directory layout.
Run Updater.bat

# Local-only update-server state
update-server/crashes/
update-server/builds/
update-server/node_modules/

# OS / editor cruft
.DS_Store
Thumbs.db
*.log
.vscode/
.idea/

# Internal staging / docs not for public repo
.repo-public-stage/
WEBSITE_BRIEF.md

# Testing artifacts
coverage/
.nyc_output/

# Disabled headset profiles (intentionally unbundled)
src/main/headsets/profiles/_*.json.disabled
